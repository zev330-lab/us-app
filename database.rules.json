{
  "rules": {
    "users": {
      "$uid": {
        ".read":  "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "couples": {
      "$cid": {
        ".read":  "auth != null && data.child('members').child(auth.uid).val() === true",
        ".write": "auth != null && (!data.exists() || data.child('members').child(auth.uid).val() === true || newData.child('members').child(auth.uid).val() === true)",
        "members": {
          "$uid": {
            ".validate": "newData.val() === true && (auth.uid == $uid || data.parent().parent().child('members').child(auth.uid).val() === true)"
          }
        },
        "history": {
          ".indexOn": ["timestamp"]
        }
      }
    },
    "inviteCodes": {
      "$code": {
        ".read":  "auth != null",
        ".write": "auth != null && (!data.exists() || data.child('redeemed').val() === false)",
        ".validate": "newData.hasChildren(['coupleId', 'createdBy', 'expiresAt', 'redeemed'])"
      }
    }
  }
}
